# Domain
BASE_DOMAIN=atgo.local
ENVIRONMENT=development

# Postgres
POSTGRES_USER=atgo
POSTGRES_PASSWORD=atgo_dev_password
POSTGRES_DB=atgo

# Redis
REDIS_PASSWORD=atgo_redis_dev

# JWT — generate with: python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=30

# CORS — list every origin that the portal might be served from
CORS_ORIGINS=http://localhost:3000,http://atgo.local,http://www.atgo.local,http://demo.atgo.local,http://api.atgo.local,http://admin.atgo.local,http://adms.atgo.local

# Portal -> API URL (used at build time and at runtime for SSR)
NEXT_PUBLIC_API_BASE=http://api.atgo.local
NEXT_PUBLIC_BASE_DOMAIN=atgo.local

# Payment providers (leave empty to disable)
PADDLE_VENDOR_ID=
PADDLE_API_KEY=
PADDLE_PUBLIC_KEY=
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Cloudflare (optional, for auto DNS)
CLOUDFLARE_GLOBAL_API_TOKEN=

# Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@atgo.io

# Sentry (optional)
SENTRY_DSN=
