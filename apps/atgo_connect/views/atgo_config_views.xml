<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_atgo_config_form" model="ir.ui.view">
        <field name="name">atgo.config.form</field>
        <field name="model">atgo.config</field>
        <field name="arch" type="xml">
            <form string="ATGO Configuration">
                <header>
                    <button name="action_test_connection" string="Test connection"
                            type="object" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="tenant_slug"/>
                            <field name="gateway_url"/>
                            <field name="api_key" password="True"/>
                            <field name="is_active"/>
                        </group>
                        <group>
                            <field name="enable_attendance_sync"/>
                            <field name="enable_employee_push"/>
                            <field name="sync_interval_minutes"/>
                            <field name="last_synced_at"/>
                        </group>
                    </group>
                    <group string="Status" col="2">
                        <field name="plan_name" readonly="1"/>
                        <field name="device_count" readonly="1"/>
                        <field name="last_error" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_atgo_config" model="ir.actions.act_window">
        <field name="name">ATGO Settings</field>
        <field name="res_model">atgo.config</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
